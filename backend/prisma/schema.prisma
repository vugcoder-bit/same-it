generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Advertisement {
  id        Int      @id @default(autoincrement())
  imageUrl  String   @db.Text
  createdAt DateTime @default(now())

  @@map("advertisement")
}

model AppSettings {
  id                   Int      @id @default(1)
  contactEmail         String?
  telegramLink         String?
  whatsappLink         String?
  aboutUs              String?  @db.Text
  intellectualProperty String?  @db.Text
  updatedAt            DateTime @default(now()) @updatedAt

  @@map("appsettings")
}

model Compatibility {
  id                   Int           @id @default(autoincrement())
  componentType        ComponentType
  deviceModelId        Int?
  subCategoryId        Int?
  compatibleModels     Json
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @default(now()) @updatedAt
  deviceModel          DeviceModel?  @relation(fields: [deviceModelId], references: [id], onDelete: Cascade)
  subCategory          ComponentSubCategory? @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)

  @@index([deviceModelId])
  @@index([subCategoryId])
  @@map("compatibility")
}

model ComponentSubCategory {
  id            Int             @id @default(autoincrement())
  componentType ComponentType
  name          String
  imageUrl      String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @default(now()) @updatedAt
  compatibility Compatibility[]

  @@unique([componentType, name])
  @@map("componentsubcategory")
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@map("contactmessage")
}

model ConversionRule {
  id           Int    @id @default(autoincrement())
  arabicLetter String
  symbol       String

  @@map("conversionrule")
}

model Device {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  imageUrl     String?       @db.Text
  deviceTypeId Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now()) @updatedAt
  deviceType   DeviceType?   @relation(fields: [deviceTypeId], references: [id])
  models       DeviceModel[]

  @@index([deviceTypeId])
  @@map("device")
}

model DeviceModel {
  id            Int             @id @default(autoincrement())
  deviceId      Int
  name          String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @default(now()) @updatedAt
  compatibility Compatibility[]
  device        Device          @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  schematic     Schematic[]

  @@unique([deviceId, name])
  @@map("devicemodel")
}

model DeviceType {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  imageUrl  String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  devices   Device[]

  @@map("devicetype")
}

model ErrorLog {
  id          Int      @id @default(autoincrement())
  errorCode   String
  description String   @db.Text
  solution    String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@map("errorlog")
}

model Order {
  id                Int           @id @default(autoincrement())
  userId            Int
  serviceId         Int
  paymentMethodId   Int
  quantity          Int           @default(1)
  totalPrice        Float         @default(0)
  phone1            String
  phone2            String?
  telegramUsername  String?
  serialNumber      String?
  paymentScreenshot String?
  notes             String?       @db.Text
  status            OrderStatus   @default(PROCESSING)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @default(now()) @updatedAt
  adminFileUrl      String?
  adminNotes        String?       @db.Text
  paymentMethod     PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)
  service           Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([paymentMethodId])
  @@index([serviceId])
  @@index([userId])
  @@map("orders")
}

model PaymentMethod {
  id            Int      @id @default(autoincrement())
  title         String
  accountNumber String
  color         String   @default("#E8632B")
  note          String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  orders        Order[]

  @@map("paymentmethod")
}

model Schematic {
  id            Int         @id @default(autoincrement())
  deviceModelId Int
  schematicType String
  pdfFile       String
  uploadedAt    DateTime    @default(now())
  updatedAt     DateTime    @default(now()) @updatedAt
  deviceModel   DeviceModel @relation(fields: [deviceModelId], references: [id], onDelete: Cascade)

  @@index([deviceModelId])
  @@map("schematic")
}

model Service {
  id              Int             @id @default(autoincrement())
  categoryId      Int
  title           String
  description     String          @db.Text
  price           Float
  duration        String?
  deliveryTime    String?
  image           String?
  requiresSN      Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @default(now()) @updatedAt
  orders          Order[]
  category        ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@map("service")
}

model ServiceCategory {
  id        Int       @id @default(autoincrement())
  name      String
  imageUrl  String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  services  Service[]

  @@map("servicecategory")
}

model User {
  id                     Int       @id @default(autoincrement())
  username               String    @unique
  password               String
  role                   Role      @default(USER)
  subscriptionExpireDate DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @default(now()) @updatedAt
  orders                 Order[]

  @@map("users")
}

enum ComponentType {
  SCREEN
  BATTERY
  CONNECTOR
  IC
  ADHESIVE
}

enum Role {
  ADMIN
  USER

  @@map("user_role")
}

enum OrderStatus {
  PROCESSING
  FAILED
  SUCCESSFUL

  @@map("order_status")
}
